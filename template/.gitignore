raw/papers/*.pdf

# 视频和音频原件（只保留转录文本）
*.mp4
*.mkv
*.avi
*.mov
*.mp3
*.wav
*.m4a
*.flac

# 大型数据文件
*.zip
*.tar.gz
*.7z
*.rar

